  @@unique([companyId, externalRef])
  @@index([companyId, batchId])
  @@index([companyId, employeeId, occurredAt])
  @@index([companyId, doorId, occurredAt])
  @@index([companyId, deviceId, occurredAt])
}

model NormalizedEvent {
  id         String @id @default(cuid())
  rawEventId String @unique
  companyId  String
  employeeId String

  occurredAt   DateTime         @db.Timestamptz(3)
  direction    EventDirection
  status       NormalizedStatus @default(PENDING)
  rejectReason String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  rawEvent RawEvent @relation(fields: [rawEventId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, occurredAt])
  @@index([status])
}

model DailyAttendance {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  workDate   DateTime @db.Date

  firstIn DateTime? @db.Timestamptz(3)
  lastOut DateTime? @db.Timestamptz(3)

  workedMinutes              Int                        @default(0)
  scheduledWorkedMinutes     Int                        @default(0)
  unscheduledWorkedMinutes   Int                        @default(0)
  overtimeMinutes            Int                        @default(0)
  scheduledOvertimeMinutes   Int                        @default(0)
  unscheduledOvertimeMinutes Int                        @default(0)
  overtimeEarlyMinutes       Int                        @default(0)
  overtimeLateMinutes        Int                        @default(0)
  /// Enterprise: OT Dynamic Break meta (engine output)
  otBreakCount               Int                        @default(0)
  otBreakDeductMinutes       Int                        @default(0)
  requiresReview             Boolean                    @default(false)
  reviewReasons              String[]                   @default([])
  reviewStatus               AttendanceReviewStatus     @default(NONE)
  reviewedAt                 DateTime?                  @db.Timestamptz(3)
  reviewedByUserId           String?
  reviewNote                 String?
  reviewLogs                 DailyAttendanceReviewLog[]
  lateMinutes                Int                        @default(0)
  earlyLeaveMinutes          Int                        @default(0)

  status      DailyStatus @default(ABSENT)
  anomalies   String[]    @default([])
  anomalyMeta Json?

  // Shift meta (engine output, SINGLE SOURCE OF TRUTH for UI/debug)
  shiftSource        String?  @db.VarChar(20) // POLICY | WEEK_TEMPLATE | DAY_TEMPLATE | CUSTOM
  shiftSignature     String?  @db.VarChar(32) // "0900-1800" | "2200-0600+1"
  shiftStartMinute   Int?
  shiftEndMinute     Int?
  shiftSpansMidnight Boolean?

  computedAt DateTime @default(now()) @db.Timestamptz(3)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, workDate])
  @@index([companyId, workDate])
  @@index([employeeId, workDate])
}

model DailyAttendanceReviewLog {
  id                String @id @default(cuid())
  companyId         String
  dailyAttendanceId String

  fromStatus    AttendanceReviewStatus?
  toStatus      AttendanceReviewStatus
  actedByUserId String?
  note          String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dailyAttendance DailyAttendance @relation(fields: [dailyAttendanceId], references: [id], onDelete: Cascade)

  @@index([companyId, dailyAttendanceId, createdAt])
  @@index([companyId, createdAt])
}

model AttendanceOwnershipAudit {
  id String @id @default(cuid())

  companyId  String
  employeeId String
  rawEventId String

  /// The DailyAttendance logical day being recomputed.
  logicalDayKey String

  occurredAt DateTime       @db.Timestamptz(3)
  direction  EventDirection

  ownerLogicalDayKey String?
  ownerSource        AttendanceOwnershipAuditOwnerSource?
  ownershipScore     Int?
  ownershipBreakdown Json?

  disposition AttendanceOwnershipAuditDisposition
  note        String?

  shiftSource    String?
  shiftSignature String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  rawEvent RawEvent @relation(fields: [rawEventId], references: [id], onDelete: Cascade)

  @@unique([rawEventId, logicalDayKey])
  @@index([companyId, logicalDayKey])
  @@index([companyId, employeeId, logicalDayKey])
  @@index([companyId, rawEventId])
}

/// Company Management: Konum Grubu
/// UI adı: Konum Grubu
/// Company tekil kalır; Konum Grubu, Company ile Branch/Konum arasındaki ara master data'dır.
model LocationGroup {
  id        String @id @default(cuid())
  companyId String

  code     String  @db.VarChar(50)
  name     String  @db.VarChar(200)
  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branches Branch[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

model Branch {
  id        String @id @default(cuid())
  companyId String
  locationGroupId String?

  code     String  @db.VarChar(50)
  name     String  @db.VarChar(200)
  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationGroup          LocationGroup?          @relation(fields: [locationGroupId], references: [id], onDelete: SetNull)
  doors                  Door[]
  devices                Device[]
  employees              Employee[]
  employeeOrgAssignments EmployeeOrgAssignment[]

  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]

  workScheduleAssignments WorkScheduleAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([locationGroupId])
  @@index([companyId, locationGroupId])
}

model Door {
  id        String @id @default(cuid())
  companyId String
  branchId  String

  code             String          @db.VarChar(50)
  name             String          @db.VarChar(200)
  role             DoorRole        @default(TIMEKEEPING)
  defaultDirection EventDirection?

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  devices   Device[]
  rawEvents RawEvent[]

  deviceInboxEvents DeviceInboxEvent[] @relation("DoorDeviceInboxEvents")

  @@unique([companyId, code])
  @@index([companyId, branchId])
}

model Device {
  id        String  @id @default(cuid())
  companyId String
  branchId  String
  doorId    String?

  name   String       @db.VarChar(200)
  vendor String?      @db.VarChar(100)
  model  String?      @db.VarChar(100)
  driver DeviceDriver @default(ZKTECO_PULL)

  ip       String? @db.VarChar(64)
  port     Int?    @default(4370)
  serialNo String? @db.VarChar(100)

  isActive Boolean @default(true)

  lastSeenAt       DateTime? @db.Timestamptz(3)
  lastSyncAt       DateTime? @db.Timestamptz(3)
  lastErrorAt      DateTime? @db.Timestamptz(3)
  lastErrorMessage String?   @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  door      Door?      @relation(fields: [doorId], references: [id], onDelete: SetNull)
  rawEvents RawEvent[]

  deviceInboxEvents DeviceInboxEvent[] @relation("DeviceDeviceInboxEvents")

  @@index([companyId])
  @@index([doorId])
  @@index([lastSeenAt])
}

model DeviceInboxEvent {
  id        String @id @default(cuid())
  companyId String

  deviceId String?
  doorId   String?

  externalRef String @db.VarChar(200)

  occurredAt DateTime       @db.Timestamptz(3)
  direction  EventDirection

  cardNo       String? @db.VarChar(100)
  deviceUserId String? @db.VarChar(100)

  status             DeviceInboxStatus @default(PENDING)
  resolvedEmployeeId String?
  resolvedAt         DateTime?         @db.Timestamptz(3)
  ignoredAt          DateTime?         @db.Timestamptz(3)

  rawPayload Json?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company Company @relation("CompanyDeviceInboxEvents", fields: [companyId], references: [id], onDelete: Cascade)
  device  Device? @relation("DeviceDeviceInboxEvents", fields: [deviceId], references: [id], onDelete: SetNull)
  door    Door?   @relation("DoorDeviceInboxEvents", fields: [doorId], references: [id], onDelete: SetNull)

  resolvedEmployee Employee? @relation("EmployeeResolvedDeviceInboxEvents", fields: [resolvedEmployeeId], references: [id], onDelete: SetNull)

  @@unique([companyId, externalRef])
  @@index([companyId, status, occurredAt])
  @@index([companyId, deviceId, occurredAt])
  @@index([companyId, cardNo])
  @@index([companyId, deviceUserId])
}

/// Weekly shift plan for an employee.
/// Stores planned start and end times (in minutes) for each day of a given week.
/// The weekStartDate must be the Monday of the week (UTC) and is unique per employee and company.
/// If a plan is provided for an employee and week, the system uses these times to compute
/// attendance metrics (late/early/overtime). When no plan exists for a day, penalties are
/// not calculated and the day is marked as "plansız" (no plan). A unique plan per employee
/// and week is enforced.
model WeeklyShiftPlan {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  weekStartDate DateTime @db.Date

  // Stage 4: Shift Assignment (SAP uyumlu)
  shiftTemplateId String? // nullable for backward compatibility

  // Stage 6: SAP Shift Assignment (day-level)
  monShiftTemplateId String?
  tueShiftTemplateId String?
  wedShiftTemplateId String?
  thuShiftTemplateId String?
  friShiftTemplateId String?
  satShiftTemplateId String?
  sunShiftTemplateId String?

  monStartMinute Int?
  monEndMinute   Int?
  tueStartMinute Int?
  tueEndMinute   Int?
  wedStartMinute Int?
  wedEndMinute   Int?
  thuStartMinute Int?
  thuEndMinute   Int?
  friStartMinute Int?
  friEndMinute   Int?
  satStartMinute Int?
  satEndMinute   Int?
  sunStartMinute Int?
  sunEndMinute   Int?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company                         Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee                        Employee                         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate                   ShiftTemplate?                   @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  integrationWeeklyShiftPlanLinks IntegrationWeeklyShiftPlanLink[]

  @@unique([companyId, employeeId, weekStartDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([shiftTemplateId])
  @@index([monShiftTemplateId])
  @@index([tueShiftTemplateId])
  @@index([wedShiftTemplateId])
  @@index([thuShiftTemplateId])
  @@index([friShiftTemplateId])
  @@index([satShiftTemplateId])
  @@index([sunShiftTemplateId])
}

model ShiftTemplate {
  id        String @id @default(cuid())
  companyId String
  /// Stable shift identity code (integration-safe). Must NOT change when times change.
  shiftCode String

  /// Customer-facing display name.
  name String @db.VarChar(120)

  /// Human signature (derived from times; can change when times change)
  signature          String
  startTime          String
  endTime            String
  spansMidnight      Boolean
  plannedWorkMinutes Int      @default(0)
  breakPlanId        String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz(3)

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  breakPlan               BreakPlan?               @relation(fields: [breakPlanId], references: [id], onDelete: SetNull)
  weeklyPlans             WeeklyShiftPlan[]
  workSchedulePatternDays WorkSchedulePatternDay[]
  importAliases           ShiftImportAlias[]

  @@unique([companyId, shiftCode])
  @@unique([companyId, signature])
  @@index([companyId])
  @@index([companyId, breakPlanId])
}

model BreakPlan {
  id        String @id @default(cuid())
  companyId String

  code                String  @db.VarChar(4)
  name                String  @db.VarChar(120)
  plannedBreakMinutes Int
  isPaid              Boolean @default(false)
  isActive            Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shiftTemplates ShiftTemplate[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

model ShiftImportAlias {
  id String @id @default(cuid())

  companyId       String
  shiftTemplateId String

  sourceValueRaw        String @db.VarChar(120)
  normalizedSourceValue String @db.VarChar(120)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)

  @@unique([companyId, normalizedSourceValue])
  @@index([companyId])
  @@index([companyId, shiftTemplateId])
  @@index([companyId, isActive])
}
