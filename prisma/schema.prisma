generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ImportProfileKind {
  EMPLOYEES
}

enum UserRole {
  SYSTEM_ADMIN
  HR_CONFIG_ADMIN
  HR_OPERATOR
  SUPERVISOR
}

/// Data visibility scope for limited roles (e.g. SUPERVISOR)
enum UserDataScope {
  ALL
  BRANCH
  EMPLOYEE_GROUP
  EMPLOYEE_SUBGROUP
}

enum EmployeeActionType {
  HIRE
  TERMINATE
  REHIRE
  UPDATE
}

enum OffDayEntryBehavior {
  IGNORE
  FLAG
  COUNT_AS_OT
}

/// Policy grouping scope (SAP-benzeri: kural seti kimde geçerli?)
enum PolicyAssignmentScope {
  EMPLOYEE
  EMPLOYEE_SUBGROUP
  EMPLOYEE_GROUP
  BRANCH
}

/// Shift-aware policy override scope (B-Model).
enum ShiftPolicyAssignmentScope {
  /// SHIFT-only override (applies to everyone on that shiftCode)
  SHIFT
  BRANCH_SHIFT
  EMPLOYEE_GROUP_SHIFT
  EMPLOYEE_SUBGROUP_SHIFT
  EMPLOYEE_SHIFT
}

/// Period work schedule assignment scope (SAP: Period Work Schedule)
enum WorkScheduleAssignmentScope {
  EMPLOYEE
  EMPLOYEE_SUBGROUP
  EMPLOYEE_GROUP
  BRANCH
}

enum EventDirection {
  IN
  OUT
}

enum EventSource {
  MANUAL
  DEVICE
  /// Internal only: bulk-generated events for automated testing.
  /// Guarded by TEST_MODE and never enabled in production.
  TEST_SEED
}

enum NormalizedStatus {
  PENDING
  PROCESSED
  REJECTED
}

enum DailyStatus {
  PRESENT
  ABSENT
  OFF
  /// Employee is on approved leave
  LEAVE
}

enum DoorRole {
  ACCESS_ONLY
  TIMEKEEPING
  BOTH
}

enum DeviceDriver {
  ZKTECO_PULL
  ZKTECO_PUSH
  GENERIC
}

enum DeviceInboxStatus {
  PENDING
  RESOLVED
  IGNORED
}

/// Integration log status for enterprise audit.
enum IntegrationLogStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model SystemSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(HR_OPERATOR)

  dataScope                UserDataScope @default(ALL)
  scopeBranchIds           String[]      @default([])
  scopeEmployeeGroupIds    String[]      @default([])
  scopeEmployeeSubgroupIds String[]      @default([])
  isActive                 Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([dataScope])
  @@index([isActive])
}

model Company {
  id   String @id @default(cuid())
  name String @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policy                 CompanyPolicy?
  policyRuleSets         PolicyRuleSet[]
  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]
  employees              Employee[]
  rawEvents              RawEvent[]
  normalizedEvents       NormalizedEvent[]
  dailyAttendances       DailyAttendance[]
  dailyAdjustments       DailyAdjustment[]

  branches Branch[]
  doors    Door[]
  devices  Device[]

  deviceInboxEvents DeviceInboxEvent[] @relation("CompanyDeviceInboxEvents")
  weeklyShiftPlans  WeeklyShiftPlan[]
  employeeLeaves    EmployeeLeave[]
  shiftTemplates    ShiftTemplate[]

  employeeEmploymentPeriods EmployeeEmploymentPeriod[]
  employeeActions           EmployeeAction[]

  importProfiles                  CompanyImportProfile[]
  integrationLogs                 IntegrationLog[]
  integrationEmployeeLinks        IntegrationEmployeeLink[]
  integrationLeaveLinks           IntegrationLeaveLink[]
  integrationWeeklyShiftPlanLinks IntegrationWeeklyShiftPlanLink[]
  integrationSecurityLogs         IntegrationSecurityLog[]
  employeeGroups                  EmployeeGroup[]
  employeeSubgroups               EmployeeSubgroup[]

  workSchedulePatterns    WorkSchedulePattern[]
  workScheduleAssignments WorkScheduleAssignment[]
  workSchedulePatternDays WorkSchedulePatternDay[]
}

/// Security/audit log for blocked integration attempts (IP, auth, config).
model IntegrationSecurityLog {
  id         String   @id @default(cuid())
  companyId  String?
  reason     String   @db.VarChar(50)
  endpoint   String   @db.VarChar(200)
  sourceIp   String?  @db.VarChar(64)
  userAgent  String?  @db.VarChar(200)
  receivedAt DateTime @default(now())

  details Json?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([reason])
  @@index([receivedAt])
}

/// Idempotency + trace link between external HR identity and internal Employee.
model IntegrationEmployeeLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  /// Optional: helps detect unchanged payloads without diffing full objects.
  lastPayloadHash String? @db.VarChar(64)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
}

/// Request-level audit log for enterprise traceability.
model IntegrationLog {
  id        String @id @default(cuid())
  companyId String

  /// Correlation id. Client may send X-Request-Id; otherwise server generates.
  requestId String @unique @db.VarChar(64)

  endpoint     String  @db.VarChar(200)
  sourceSystem String  @db.VarChar(50)
  batchRef     String? @db.VarChar(200)

  ip         String? @db.VarChar(64)
  /// Never store the API key itself. Store a hash/fingerprint for traceability.
  apiKeyHash String? @db.VarChar(64)

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  totalCount     Int @default(0)
  createdCount   Int @default(0)
  updatedCount   Int @default(0)
  unchangedCount Int @default(0)
  failedCount    Int @default(0)

  status IntegrationLogStatus @default(SUCCESS)

  /// Optional JSONB details.
  errors      Json?
  payloadMeta Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sourceSystem, receivedAt])
}

/// Idempotency link for externally managed leaves (EmployeeLeave).
model IntegrationLeaveLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId String
  leaveId    String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  lastPayloadHash String? @db.VarChar(64)

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leave    EmployeeLeave @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
  @@index([companyId, leaveId])
}

/// Idempotency link for WeeklyShiftPlan (shift assignments).
model IntegrationWeeklyShiftPlanLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId        String
  weeklyShiftPlanId String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  lastPayloadHash String? @db.VarChar(64)

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  weeklyShiftPlan WeeklyShiftPlan @relation(fields: [weeklyShiftPlanId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
  @@index([companyId, weeklyShiftPlanId])
}

model CompanyImportProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  kind    ImportProfileKind
  mapping Json

  @@unique([companyId, kind])
  @@index([companyId])
}

model CompanyPolicy {
  id        String @id @default(cuid())
  companyId String @unique

  timezone               String @default("Europe/Istanbul") @db.VarChar(64)
  shiftStartMinute       Int    @default(540)
  shiftEndMinute         Int    @default(1080)
  breakMinutes           Int    @default(60)
  lateGraceMinutes       Int    @default(5)
  earlyLeaveGraceMinutes Int    @default(5)

  breakAutoDeductEnabled Boolean             @default(true)
  offDayEntryBehavior    OffDayEntryBehavior @default(IGNORE)
  overtimeEnabled        Boolean             @default(false)

  /// Determines how punches are treated on an approved leave day.
  /// Reuses the OffDayEntryBehavior enum for consistency.
  /// - IGNORE: Any punches on a leave day are ignored. Worked and overtime minutes are zeroed.
  /// - FLAG: Punches are counted towards worked minutes (but overtime minutes are zero) and an anomaly is recorded.
  /// - COUNT_AS_OT: Punches are ignored for worked minutes but counted as overtime. An anomaly is recorded.
  leaveEntryBehavior OffDayEntryBehavior @default(FLAG)

  /// Opsiyonel: grace dakikalarının çalışılan süreye dahil edilip edilmeyeceği
  graceAffectsWorked   Boolean?
  /// Opsiyonel: çıkış sürelerinin moladan düşülüp düşülmeyeceği
  exitConsumesBreak    Boolean?
  /// Opsiyonel: tek bir çıkış için izin verilen maksimum dakika
  maxSingleExitMinutes Int?
  /// Opsiyonel: bir gün içinde toplam izin verilen çıkış dakikası
  maxDailyExitMinutes  Int?
  /// Opsiyonel: çıkış süreleri limitleri aştığında alınacak aksiyon
  exitExceedAction     ExitExceedAction?

  /// Grace mode to specify how grace minutes are treated.
  /// - ROUND_ONLY: grace minutes are only used for rounding/tolerance and are not added to worked minutes.
  /// - PAID_PARTIAL: grace minutes within the threshold are added to worked minutes.
  graceMode GraceMode @default(ROUND_ONLY)

  /// Worked minutes calculation mode.
  /// - ACTUAL: workedMinutes is based on accepted IN->OUT segments (existing behavior).
  /// - CLAMP_TO_SHIFT: segments are clamped to [shiftStart, shiftEnd] so early/late time doesn't inflate worked.
  workedCalculationMode WorkedCalculationMode @default(ACTUAL)

  /// Enterprise: Overtime dynamic break.
  /// Example: every 180 minutes of overtime => 30 minutes break deducted from payable overtime.
  /// If either value is null, the feature is disabled.
  otBreakInterval Int?
  otBreakDuration Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/// Workforce Segment (SAP: Employee Group)
model EmployeeGroup {
  id        String @id @default(cuid())
  companyId String

  /// Stable code (e.g. WHITE, BLUE)
  code String @db.VarChar(50)
  name String @db.VarChar(120)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  subgroups              EmployeeSubgroup[]
  employees              Employee[]
  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]

  workScheduleAssignments WorkScheduleAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
}

/// Workforce Sub-Segment (SAP: Employee Subgroup)
model EmployeeSubgroup {
  id        String @id @default(cuid())
  companyId String

  groupId String

  /// Stable code (e.g. WHITE_MANAGER, BLUE_NIGHT)
  code String @db.VarChar(50)
  name String @db.VarChar(120)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  group   EmployeeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  employees              Employee[]
  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]

  workScheduleAssignments WorkScheduleAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, groupId])
}

/// Period Work Schedule pattern (SAP: PWS / Work Schedule Rule)
/// - Defines an N-day cycle mapped to ShiftTemplate ids.
/// - referenceDate is the canonical anchor day of cycle index 0.
model WorkSchedulePattern {
  id        String @id @default(cuid())
  companyId String

  /// Stable code (e.g. VR01, MV01)
  code String @db.VarChar(50)
  name String @db.VarChar(120)

  cycleLengthDays Int
  referenceDate   DateTime @db.Date

  /// Length = cycleLengthDays. Each entry is a ShiftTemplate.id.
  /// NOTE: OFF handling is not encoded here yet; use an explicit OFF ShiftTemplate if needed.
  dayShiftTemplateIds String[]

  /// Enterprise OFF semantics: child rows (shiftTemplateId NULL => OFF)
  days WorkSchedulePatternDay[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignments WorkScheduleAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

/// Enterprise: day-level pattern rows (SAP-like).
/// - dayIndex is 0..cycleLengthDays-1
/// - shiftTemplateId NULL => OFF (must NOT fallback to Policy)
model WorkSchedulePatternDay {
  id        String @id @default(cuid())
  companyId String

  patternId       String
  dayIndex        Int
  shiftTemplateId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pattern       WorkSchedulePattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate?      @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)

  @@unique([companyId, patternId, dayIndex])
  @@index([companyId])
  @@index([companyId, patternId])
  @@index([companyId, shiftTemplateId])
}

/// Period Work Schedule assignment (time-sliced).
/// SAP-like precedence:
/// - More specific scope should win (EMPLOYEE > SUBGROUP > GROUP > BRANCH)
/// - Within same scope, higher priority wins.
model WorkScheduleAssignment {
  id        String @id @default(cuid())
  companyId String

  scope    WorkScheduleAssignmentScope
  priority Int                         @default(0)

  validFrom DateTime? @db.Date
  validTo   DateTime? @db.Date

  patternId String

  employeeId         String?
  employeeSubgroupId String?
  employeeGroupId    String?
  branchId           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pattern WorkSchedulePattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  employee         Employee?         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeSubgroup EmployeeSubgroup? @relation(fields: [employeeSubgroupId], references: [id], onDelete: Cascade)
  employeeGroup    EmployeeGroup?    @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, scope])
  @@index([companyId, patternId])
  @@index([companyId, employeeId])
  @@index([companyId, employeeSubgroupId])
  @@index([companyId, employeeGroupId])
  @@index([companyId, branchId])
  @@index([companyId, validFrom])
  @@index([companyId, validTo])
}

/// Company-level policy rule set (policy group / variant).
/// NOTE: CompanyPolicy remains the legacy/default single-policy record.
model PolicyRuleSet {
  id        String @id @default(cuid())
  companyId String

  /// Stable code for integrations / references (e.g. DEFAULT, WHITE_COLLAR, BLUE_COLLAR)
  code String @db.VarChar(50)
  name String @db.VarChar(120)

  /// Rule fields (timezone stays company-level; this is evaluation rules only)
  shiftStartMinute       Int
  shiftEndMinute         Int
  breakMinutes           Int
  lateGraceMinutes       Int
  earlyLeaveGraceMinutes Int

  breakAutoDeductEnabled Boolean
  offDayEntryBehavior    OffDayEntryBehavior
  overtimeEnabled        Boolean
  leaveEntryBehavior     OffDayEntryBehavior

  graceAffectsWorked   Boolean?
  exitConsumesBreak    Boolean?
  maxSingleExitMinutes Int?
  maxDailyExitMinutes  Int?
  exitExceedAction     ExitExceedAction?

  graceMode             GraceMode
  workedCalculationMode WorkedCalculationMode
  otBreakInterval       Int?
  otBreakDuration       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company                Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments            PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
}

/// Assignment of a policy rule set to an entity (Phase-1: EMPLOYEE only).
model PolicyAssignment {
  id        String @id @default(cuid())
  companyId String

  scope PolicyAssignmentScope

  /// Target entity ids (based on scope)
  employeeId         String?
  employeeSubgroupId String?
  employeeGroupId    String?
  branchId           String?

  ruleSetId String

  /// Optional validity slicing (SAP-like). Stored as @db.Date.
  validFrom DateTime? @db.Date
  validTo   DateTime? @db.Date

  /// Higher wins if multiple match (future-proof).
  priority Int @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee?         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeSubgroup EmployeeSubgroup? @relation(fields: [employeeSubgroupId], references: [id], onDelete: Cascade)
  employeeGroup    EmployeeGroup?    @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ruleSet          PolicyRuleSet     @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([companyId, scope])
  @@index([companyId, employeeId])
  @@index([companyId, employeeSubgroupId])
  @@index([companyId, employeeGroupId])
  @@index([companyId, branchId])
  @@index([companyId, ruleSetId])
}

model ShiftPolicyAssignment {
  id        String @id @default(cuid())
  companyId String

  scope ShiftPolicyAssignmentScope

  /// Stable shift identity (ShiftTemplate.shiftCode)
  shiftCode String @db.VarChar(80)

  /// Target entity ids (based on scope)
  employeeId         String?
  employeeSubgroupId String?
  employeeGroupId    String?
  branchId           String?

  ruleSetId String

  /// Optional validity slicing (SAP-like). Stored as @db.Date.
  validFrom DateTime? @db.Date
  validTo   DateTime? @db.Date

  /// Higher wins if multiple match.
  priority Int @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee?         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeSubgroup EmployeeSubgroup? @relation(fields: [employeeSubgroupId], references: [id], onDelete: Cascade)
  employeeGroup    EmployeeGroup?    @relation(fields: [employeeGroupId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ruleSet          PolicyRuleSet     @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@index([companyId, scope])
  @@index([companyId, shiftCode])
  @@index([companyId, shiftCode, employeeId])
  @@index([companyId, shiftCode, employeeSubgroupId])
  @@index([companyId, shiftCode, employeeGroupId])
  @@index([companyId, shiftCode, branchId])
  @@index([companyId, ruleSetId])
}

/// Types of employee leave.
/// All leave records must specify a type.
enum LeaveType {
  ANNUAL
  SICK
  EXCUSED
  UNPAID
}

model EmployeeLeave {
  id         String @id @default(cuid())
  companyId  String
  employeeId String

  /// UTC start of leave (inclusive)
  dateFrom DateTime
  /// UTC end of leave (inclusive)
  dateTo   DateTime

  type LeaveType
  note String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee              Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  integrationLeaveLinks IntegrationLeaveLink[]

  @@index([companyId])
  @@index([employeeId])
  @@index([dateFrom])
  @@index([dateTo])
  @@index([companyId, employeeId])
  @@index([employeeId, dateFrom, dateTo])
}

/// Çıkış süresi limitleri aşıldığında raporlama aksiyonları
enum ExitExceedAction {
  IGNORE
  WARN
  FLAG
}

/// Modes for grace minute handling.
/// ROUND_ONLY: grace minutes are only used as tolerance; they do not add to worked time.
/// PAID_PARTIAL: grace minutes within the threshold count as worked minutes.
enum GraceMode {
  ROUND_ONLY
  PAID_PARTIAL
}

/// Worked minutes calculation modes.
/// ACTUAL: workedMinutes is based on accepted IN->OUT segments (existing behavior).
/// CLAMP_TO_SHIFT: segments are clamped to [shiftStart, shiftEnd] so early/late time doesn't inflate worked.
enum WorkedCalculationMode {
  ACTUAL
  CLAMP_TO_SHIFT
}

model DailyAdjustment {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  date       DateTime @db.Date

  /// Override status. When set, this replaces the computed DailyStatus for the day.
  statusOverride               DailyStatus?
  /// Override total worked minutes. Null means use computed value.
  workedMinutesOverride        Int?
  /// Override overtime minutes. Null means use computed value.
  overtimeMinutesOverride      Int?
  /// Override overtime early minutes. Null means use computed value.
  overtimeEarlyMinutesOverride Int?
  /// Override overtime late minutes. Null means use computed value.
  overtimeLateMinutesOverride  Int?
  /// Override late minutes. Null means use computed value.
  lateMinutesOverride          Int?
  /// Override early leave minutes. Null means use computed value.
  earlyLeaveMinutesOverride    Int?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([companyId])
  @@index([employeeId])
  @@index([date])
}

model Employee {
  id        String @id @default(cuid())
  companyId String

  employeeCode String  @db.VarChar(50)
  firstName    String  @db.VarChar(100)
  lastName     String  @db.VarChar(100)
  email        String? @db.VarChar(320)

  cardNo       String? @db.VarChar(100)
  deviceUserId String? @db.VarChar(100)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  employeeGroupId    String?
  employeeSubgroupId String?

  employeeGroup    EmployeeGroup?    @relation(fields: [employeeGroupId], references: [id], onDelete: SetNull)
  employeeSubgroup EmployeeSubgroup? @relation(fields: [employeeSubgroupId], references: [id], onDelete: SetNull)

  isActive     Boolean   @default(true)
  hiredAt      DateTime?
  terminatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rawEvents        RawEvent[]
  normalizedEvents NormalizedEvent[]
  dailyAttendances DailyAttendance[]
  dailyAdjustments DailyAdjustment[]

  resolvedDeviceInboxEvents       DeviceInboxEvent[]               @relation("EmployeeResolvedDeviceInboxEvents")
  weeklyShiftPlans                WeeklyShiftPlan[]
  employeeLeaves                  EmployeeLeave[]
  employmentPeriods               EmployeeEmploymentPeriod[]
  employeeActions                 EmployeeAction[]
  integrationEmployeeLinks        IntegrationEmployeeLink[]
  integrationLeaveLinks           IntegrationLeaveLink[]
  integrationWeeklyShiftPlanLinks IntegrationWeeklyShiftPlanLink[]
  policyAssignments               PolicyAssignment[]
  shiftPolicyAssignments          ShiftPolicyAssignment[]

  workScheduleAssignments WorkScheduleAssignment[]

  @@unique([companyId, employeeCode])
  @@unique([companyId, cardNo])
  @@unique([companyId, deviceUserId])
  @@index([companyId])
  @@index([isActive])
  @@index([companyId, cardNo])
  @@index([companyId, deviceUserId])
  @@index([companyId, branchId])
  @@index([companyId, employeeGroupId])
  @@index([companyId, employeeSubgroupId])
}

/// Employment validity periods (SAP-like time-sliced employment records).
/// - startDate / endDate are calendar dates stored as @db.Date.
/// - endDate = null means "open-ended" (currently employed).
model EmployeeEmploymentPeriod {
  id         String @id @default(cuid())
  companyId  String
  employeeId String

  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date

  /// Optional HR reason / note (e.g., termination reason)
  reason String? @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId])
  @@index([employeeId, startDate])
  @@index([companyId, startDate])
}

/// HR audit trail for employee lifecycle actions (enterprise traceability).
model EmployeeAction {
  id         String @id @default(cuid())
  companyId  String
  employeeId String

  type          EmployeeActionType
  effectiveDate DateTime           @db.Date

  note        String? @db.VarChar(200)
  actorUserId String? @db.VarChar(64)
  details     Json?

  createdAt DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId])
  @@index([companyId, type])
  @@index([companyId, effectiveDate])
}

model RawEvent {
  id         String @id @default(cuid())
  companyId  String
  employeeId String

  doorId   String?
  deviceId String?

  externalRef String? @db.VarChar(200)

  /// Internal-only grouping for bulk test seeding.
  /// When present, allows fast cleanup by batch.
  batchId String? @db.VarChar(64)
  /// Optional scenario note (e.g. MISSING_PUNCH_IN)
  note    String? @db.VarChar(200)

  occurredAt DateTime
  direction  EventDirection
  source     EventSource    @default(MANUAL)

  createdAt DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  door   Door?   @relation(fields: [doorId], references: [id], onDelete: SetNull)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  normalized NormalizedEvent?

  @@unique([companyId, externalRef])
  @@index([companyId, batchId])
  @@index([companyId, employeeId, occurredAt])
  @@index([companyId, doorId, occurredAt])
  @@index([companyId, deviceId, occurredAt])
}

model NormalizedEvent {
  id         String @id @default(cuid())
  rawEventId String @unique
  companyId  String
  employeeId String

  occurredAt   DateTime
  direction    EventDirection
  status       NormalizedStatus @default(PENDING)
  rejectReason String?

  createdAt DateTime @default(now())

  rawEvent RawEvent @relation(fields: [rawEventId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, occurredAt])
  @@index([status])
}

model DailyAttendance {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  workDate   DateTime @db.Date

  firstIn DateTime?
  lastOut DateTime?

  workedMinutes        Int @default(0)
  overtimeMinutes      Int @default(0)
  overtimeEarlyMinutes Int @default(0)
  overtimeLateMinutes  Int @default(0)
  /// Enterprise: OT Dynamic Break meta (engine output)
  otBreakCount         Int @default(0)
  otBreakDeductMinutes Int @default(0)
  lateMinutes          Int @default(0)
  earlyLeaveMinutes    Int @default(0)

  status    DailyStatus @default(ABSENT)
  anomalies String[]    @default([])

  // Shift meta (engine output, SINGLE SOURCE OF TRUTH for UI/debug)
  shiftSource        String?  @db.VarChar(20) // POLICY | WEEK_TEMPLATE | DAY_TEMPLATE | CUSTOM
  shiftSignature     String?  @db.VarChar(32) // "0900-1800" | "2200-0600+1"
  shiftStartMinute   Int?
  shiftEndMinute     Int?
  shiftSpansMidnight Boolean?

  computedAt DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, workDate])
  @@index([companyId, workDate])
  @@index([employeeId, workDate])
}

model Branch {
  id        String @id @default(cuid())
  companyId String

  code     String  @db.VarChar(50)
  name     String  @db.VarChar(200)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  doors     Door[]
  devices   Device[]
  employees Employee[]

  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]

  workScheduleAssignments WorkScheduleAssignment[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Door {
  id        String @id @default(cuid())
  companyId String
  branchId  String

  code             String          @db.VarChar(50)
  name             String          @db.VarChar(200)
  role             DoorRole        @default(TIMEKEEPING)
  defaultDirection EventDirection?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  devices   Device[]
  rawEvents RawEvent[]

  deviceInboxEvents DeviceInboxEvent[] @relation("DoorDeviceInboxEvents")

  @@unique([companyId, code])
  @@index([companyId, branchId])
}

model Device {
  id        String  @id @default(cuid())
  companyId String
  branchId  String
  doorId    String?

  name   String       @db.VarChar(200)
  vendor String?      @db.VarChar(100)
  model  String?      @db.VarChar(100)
  driver DeviceDriver @default(ZKTECO_PULL)

  ip       String? @db.VarChar(64)
  port     Int?    @default(4370)
  serialNo String? @db.VarChar(100)

  isActive Boolean @default(true)

  lastSeenAt       DateTime?
  lastSyncAt       DateTime?
  lastErrorAt      DateTime?
  lastErrorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  door      Door?      @relation(fields: [doorId], references: [id], onDelete: SetNull)
  rawEvents RawEvent[]

  deviceInboxEvents DeviceInboxEvent[] @relation("DeviceDeviceInboxEvents")

  @@index([companyId])
  @@index([doorId])
  @@index([lastSeenAt])
}

model DeviceInboxEvent {
  id        String @id @default(cuid())
  companyId String

  deviceId String?
  doorId   String?

  externalRef String @db.VarChar(200)

  occurredAt DateTime
  direction  EventDirection

  cardNo       String? @db.VarChar(100)
  deviceUserId String? @db.VarChar(100)

  status             DeviceInboxStatus @default(PENDING)
  resolvedEmployeeId String?
  resolvedAt         DateTime?
  ignoredAt          DateTime?

  rawPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation("CompanyDeviceInboxEvents", fields: [companyId], references: [id], onDelete: Cascade)
  device  Device? @relation("DeviceDeviceInboxEvents", fields: [deviceId], references: [id], onDelete: SetNull)
  door    Door?   @relation("DoorDeviceInboxEvents", fields: [doorId], references: [id], onDelete: SetNull)

  resolvedEmployee Employee? @relation("EmployeeResolvedDeviceInboxEvents", fields: [resolvedEmployeeId], references: [id], onDelete: SetNull)

  @@unique([companyId, externalRef])
  @@index([companyId, status, occurredAt])
  @@index([companyId, deviceId, occurredAt])
  @@index([companyId, cardNo])
  @@index([companyId, deviceUserId])
}

/// Weekly shift plan for an employee.
/// Stores planned start and end times (in minutes) for each day of a given week.
/// The weekStartDate must be the Monday of the week (UTC) and is unique per employee and company.
/// If a plan is provided for an employee and week, the system uses these times to compute
/// attendance metrics (late/early/overtime). When no plan exists for a day, penalties are
/// not calculated and the day is marked as "plansız" (no plan). A unique plan per employee
/// and week is enforced.
model WeeklyShiftPlan {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  weekStartDate DateTime

  // Stage 4: Shift Assignment (SAP uyumlu)
  shiftTemplateId String? // nullable for backward compatibility

  // Stage 6: SAP Shift Assignment (day-level)
  monShiftTemplateId String?
  tueShiftTemplateId String?
  wedShiftTemplateId String?
  thuShiftTemplateId String?
  friShiftTemplateId String?
  satShiftTemplateId String?
  sunShiftTemplateId String?

  monStartMinute Int?
  monEndMinute   Int?
  tueStartMinute Int?
  tueEndMinute   Int?
  wedStartMinute Int?
  wedEndMinute   Int?
  thuStartMinute Int?
  thuEndMinute   Int?
  friStartMinute Int?
  friEndMinute   Int?
  satStartMinute Int?
  satEndMinute   Int?
  sunStartMinute Int?
  sunEndMinute   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company                         Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee                        Employee                         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate                   ShiftTemplate?                   @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  integrationWeeklyShiftPlanLinks IntegrationWeeklyShiftPlanLink[]

  @@unique([companyId, employeeId, weekStartDate])
  @@index([companyId])
  @@index([employeeId])
  @@index([shiftTemplateId])
  @@index([monShiftTemplateId])
  @@index([tueShiftTemplateId])
  @@index([wedShiftTemplateId])
  @@index([thuShiftTemplateId])
  @@index([friShiftTemplateId])
  @@index([satShiftTemplateId])
  @@index([sunShiftTemplateId])
}

model ShiftTemplate {
  id        String @id @default(cuid())
  companyId String
  /// Stable shift identity code (integration-safe). Must NOT change when times change.
  shiftCode String

  /// Human signature (derived from times; can change when times change)
  signature     String
  startTime     String
  endTime       String
  spansMidnight Boolean
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  weeklyPlans             WeeklyShiftPlan[]
  workSchedulePatternDays WorkSchedulePatternDay[]

  @@unique([companyId, shiftCode])
  @@unique([companyId, signature])
  @@index([companyId])
}
