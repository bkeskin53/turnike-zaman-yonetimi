generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ImportProfileKind {
  EMPLOYEES
}

enum ScreenConfigurationScreenKey {
  EMPLOYEES_CREATE              @map("employees.create")
  EMPLOYEES_MASTER              @map("employees.master")
  EMPLOYEES_MASTER_DISPLAY      @map("employees.master.display")
  EMPLOYEES_MASTER_HISTORY      @map("employees.master.history")
  EMPLOYEES_MASTER_HISTORY_FORM @map("employees.master.history.form")
  EMPLOYEES_MASTER_HISTORY_LIST @map("employees.master.history.list")
}

enum ScreenConfigurationFieldKey {
  GENDER         @map("gender")
  EMAIL          @map("email")
  PHONE          @map("phone")
  CARD_NO        @map("cardNo")
  DEVICE_USER_ID @map("deviceUserId")
}

enum UserRole {
  SYSTEM_ADMIN
  HR_CONFIG_ADMIN
  HR_OPERATOR
  SUPERVISOR
}

/// Data visibility scope for limited roles (e.g. SUPERVISOR)
enum UserDataScope {
  ALL
  BRANCH
  EMPLOYEE_GROUP
  EMPLOYEE_SUBGROUP
}

enum AttendanceReviewStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum PayrollPeriodStatus {
  OPEN
  PRE_CLOSED
  CLOSED
}

enum PayrollSnapshotStatus {
  DRAFT
  FINAL
}

enum PayrollSnapshotQuantityUnit {
  MINUTES
  DAYS
  COUNT
}

enum PayrollCodeMappingItemUnit {
  MINUTES
  DAYS
  COUNT
}

enum PayrollCodeMappingQuantityStrategy {
  WORKED_MINUTES
  OVERTIME_MINUTES
  FIXED_QUANTITY
}

enum PayrollAuditEventType {
  REVIEW_STATUS_CHANGED
  REVIEW_NOTE_CHANGED
  PERIOD_PRE_CLOSED
  PERIOD_CLOSED
  PERIOD_REOPENED
  SNAPSHOT_CREATED
  MONTHLY_EXPORT_CREATED
  DAILY_EXPORT_CREATED
  PAYROLL_MAPPING_PROFILE_CREATED
  PAYROLL_MAPPING_PROFILE_UPDATED
  PAYROLL_MAPPING_PROFILE_DEFAULT_CHANGED
  PAYROLL_MAPPING_PROFILE_ACTIVE_CHANGED
  PAYROLL_MAPPING_ITEM_UPSERTED
  PAYROLL_MAPPING_ITEM_DEACTIVATED
}

enum PayrollAuditEntityType {
  PAYROLL_PERIOD
  PAYROLL_PERIOD_SNAPSHOT
  DAILY_ATTENDANCE
  EMPLOYEE
  EXPORT
  PAYROLL_MAPPING_PROFILE
  PAYROLL_MAPPING_ITEM
}

enum EmployeeActionType {
  HIRE
  TERMINATE
  REHIRE
  UPDATE
}

enum OffDayEntryBehavior {
  IGNORE
  FLAG
  COUNT_AS_OT
}

enum AttendanceOwnershipAuditDisposition {
  SCHEDULED
  VISIBLE_UNSCHEDULED
  OWNED_OTHER_LOGICAL_DAY
  IGNORED
}

enum AttendanceOwnershipAuditOwnerSource {
  PREVIOUS_DAY
  CURRENT_DAY
  NEXT_DAY
}

/// Event ownership strategy for the attendance engine.
/// WINDOW = legacy day-window capture
/// INSTANCE_SCORING = enterprise instance-based ownership
enum AttendanceOwnershipMode {
  WINDOW
  INSTANCE_SCORING
}

/// How valid unscheduled work should behave in the engine.
enum UnscheduledWorkBehavior {
  IGNORE
  FLAG_ONLY
  COUNT_AS_OT
}

/// Policy grouping scope (SAP-benzeri: kural seti kimde geçerli?)
enum PolicyAssignmentScope {
  EMPLOYEE
  EMPLOYEE_SUBGROUP
  EMPLOYEE_GROUP
  BRANCH
}

/// Shift-aware policy override scope (B-Model).
enum ShiftPolicyAssignmentScope {
  /// SHIFT-only override (applies to everyone on that shiftCode)
  SHIFT
  BRANCH_SHIFT
  EMPLOYEE_GROUP_SHIFT
  EMPLOYEE_SUBGROUP_SHIFT
  EMPLOYEE_SHIFT
}

/// Period work schedule assignment scope (SAP: Period Work Schedule)
enum WorkScheduleAssignmentScope {
  EMPLOYEE
  EMPLOYEE_SUBGROUP
  EMPLOYEE_GROUP
  BRANCH
}

enum EventDirection {
  IN
  OUT
}

enum EventSource {
  MANUAL
  DEVICE
  /// Internal only: bulk-generated events for automated testing.
  /// Guarded by TEST_MODE and never enabled in production.
  TEST_SEED
}

enum NormalizedStatus {
  PENDING
  PROCESSED
  REJECTED
}

enum DailyStatus {
  PRESENT
  ABSENT
  OFF
  /// Employee is on approved leave
  LEAVE
}

enum DoorRole {
  ACCESS_ONLY
  TIMEKEEPING
  BOTH
}

enum DeviceDriver {
  ZKTECO_PULL
  ZKTECO_PUSH
  GENERIC
}

enum DeviceInboxStatus {
  PENDING
  RESOLVED
  IGNORED
}

/// Integration log status for enterprise audit.
enum IntegrationLogStatus {
  SUCCESS
  PARTIAL
  FAILED
}

/// Admin audit actions (enterprise traceability).
enum AuditAction {
  USER_CREATED
  USER_ROLE_CHANGED
  USER_STATUS_CHANGED
  USER_PASSWORD_RESET
  SUPERVISOR_SCOPE_UPDATED
  RECOMPUTE
  IMPORT
  POLICY_UPDATE
  MANUAL_EVENT
  EMPLOYEE_HARD_DELETE

  RULESET_UPDATED
  POLICY_ASSIGNMENT_UPDATED
  SHIFT_TEMPLATE_UPDATED
  BREAK_PLAN_UPDATED
  WORK_SCHEDULE_UPDATED
  SHIFT_ASSIGNMENT_UPDATED
  WORKFORCE_UPDATED
  CONFIGURATION_UPDATED
}

enum AuditTargetType {
  USER
  ATTENDANCE
  EMPLOYEES
  POLICY
  EVENT

  RULESET
  POLICY_ASSIGNMENT
  SHIFT_TEMPLATE
  BREAK_PLAN
  WORK_SCHEDULE
  SHIFT_ASSIGNMENT
  WORKFORCE
  CONFIGURATION
}

enum RecomputeReason {
  POLICY_UPDATE
  RULESET_UPDATED
  POLICY_ASSIGNMENT_UPDATED
  SHIFT_TEMPLATE_UPDATED
  WORK_SCHEDULE_UPDATED
  SHIFT_ASSIGNMENT_UPDATED
  WORKFORCE_UPDATED
}

enum RecomputeStatus {
  PENDING
  RUNNING
  DONE
}

enum EmployeeImportRunMode {
  DRY_RUN
  APPLY
}

enum EmployeeImportRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum EmployeeImportRunOutcome {
  CLEAN
  WARNING
  BLOCKING
  PARTIAL
}

model RecomputeRequirement {
  id        String          @id @default(cuid())
  companyId String
  reason    RecomputeReason

  /// Canonical day keys (policy timezone) in YYYY-MM-DD. Nullable = unknown (no guessing).
  rangeStartDayKey String?
  rangeEndDayKey   String?

  status RecomputeStatus @default(PENDING)

  createdByUserId String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)

  resolvedByUserId String?
  resolvedAt       DateTime? @db.Timestamptz(3)
  lastRunAt        DateTime? @db.Timestamptz(3)

  @@index([companyId, status])
  @@index([companyId, reason, status])
  @@index([createdAt])
}

model EmployeeImportRun {
  id        String @id @default(cuid())
  companyId String

  sheetKind  String                    @db.VarChar(32)
  sheetTitle String                    @db.VarChar(120)
  mode       EmployeeImportRunMode     @default(APPLY)
  status     EmployeeImportRunStatus   @default(RUNNING)
  outcome    EmployeeImportRunOutcome?

  contentHash String @db.VarChar(64)
  actorUserId String

  requestedCount Int
  processedCount Int?
  foundCount     Int?
  changedCount   Int?
  unchangedCount Int?
  rejectedCount  Int?
  warningCount   Int?
  errorCount     Int?

  headerSummarySnapshot       Json?
  codeResolutionSnapshot      Json?
  applySummarySnapshot        Json?
  changedEmployeeCodesPreview String[] @default([])
  warningsPreview             Json?
  errorsPreview               Json?

  duplicateOfRunId String?
  failedCode       String? @db.VarChar(100)
  failedMessage    String? @db.Text

  startedAt  DateTime  @default(now()) @db.Timestamptz(3)
  finishedAt DateTime? @db.Timestamptz(3)

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  duplicateOfRun EmployeeImportRun?  @relation("EmployeeImportRunDuplicate", fields: [duplicateOfRunId], references: [id], onDelete: SetNull)
  duplicateRuns  EmployeeImportRun[] @relation("EmployeeImportRunDuplicate")

  @@index([companyId, mode, startedAt])
  @@index([companyId, sheetKind, startedAt])
  @@index([companyId, sheetKind, status, startedAt])
  @@index([companyId, sheetKind, outcome, startedAt])
  @@index([companyId, sheetKind, contentHash, startedAt])
  @@index([actorUserId])
}

model EmployeeImportApplyLock {
  id        String @id @default(cuid())
  companyId String

  sheetKind   String   @db.VarChar(32)
  actorUserId String
  acquiredAt  DateTime @default(now()) @db.Timestamptz(3)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, sheetKind])
  @@index([acquiredAt])
}

model SystemSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(320)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(HR_OPERATOR)

  dataScope                UserDataScope @default(ALL)
  scopeBranchIds           String[]      @default([])
  scopeEmployeeGroupIds    String[]      @default([])
  scopeEmployeeSubgroupIds String[]      @default([])
  isActive                 Boolean       @default(true)

  createdAt                     DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt                     DateTime                @updatedAt @db.Timestamptz(3)
  auditLogs                     AuditLog[]
  preClosedPayrollPeriods       PayrollPeriod[]         @relation("PayrollPeriodPreClosedByUser")
  closedPayrollPeriods          PayrollPeriod[]         @relation("PayrollPeriodClosedByUser")
  createdPayrollPeriodSnapshots PayrollPeriodSnapshot[] @relation("PayrollPeriodSnapshotCreatedByUser")
  payrollAuditEvents            PayrollAuditEvent[]     @relation("PayrollAuditEventActorUser")

  @@index([role])
  @@index([dataScope])
  @@index([isActive])
}

/// Enterprise audit log for admin actions (RBAC/security traceability).
model AuditLog {
  id          String          @id @default(cuid())
  actorUserId String
  actorRole   UserRole
  action      AuditAction
  targetType  AuditTargetType
  targetId    String?

  endpoint  String? @db.VarChar(200)
  method    String? @db.VarChar(16)
  sourceIp  String? @db.VarChar(64)
  userAgent String? @db.VarChar(200)

  details   Json?
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model Company {
  id   String @id @default(cuid())
  name String @db.VarChar(200)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  policy                 CompanyPolicy?
  policyRuleSets         PolicyRuleSet[]
  policyAssignments      PolicyAssignment[]
  shiftPolicyAssignments ShiftPolicyAssignment[]
  employees              Employee[]
  rawEvents              RawEvent[]
  normalizedEvents       NormalizedEvent[]
  dailyAttendances       DailyAttendance[]
  dailyAdjustments       DailyAdjustment[]

  locationGroups LocationGroup[]
  branches       Branch[]
  doors          Door[]
  devices        Device[]

  deviceInboxEvents         DeviceInboxEvent[]         @relation("CompanyDeviceInboxEvents")
  weeklyShiftPlans          WeeklyShiftPlan[]
  employeeLeaves            EmployeeLeave[]
  attendanceOwnershipAudits AttendanceOwnershipAudit[]
  dailyAttendanceReviewLogs DailyAttendanceReviewLog[]

  shiftTemplates     ShiftTemplate[]
  breakPlans         BreakPlan[]
  shiftImportAliases ShiftImportAlias[]

  employeeEmploymentPeriods EmployeeEmploymentPeriod[]
  employeeActions           EmployeeAction[]
  employeeProfileVersions   EmployeeProfileVersion[]
  employeeOrgAssignments    EmployeeOrgAssignment[]
  employeeImportRuns        EmployeeImportRun[]
  employeeImportApplyLocks  EmployeeImportApplyLock[]

  importProfiles                  CompanyImportProfile[]
  integrationLogs                 IntegrationLog[]
  integrationEmployeeLinks        IntegrationEmployeeLink[]
  integrationLeaveLinks           IntegrationLeaveLink[]
  integrationWeeklyShiftPlanLinks IntegrationWeeklyShiftPlanLink[]
  integrationSecurityLogs         IntegrationSecurityLog[]
  employeeGroups                  EmployeeGroup[]
  employeeSubgroups               EmployeeSubgroup[]

  workSchedulePatterns        WorkSchedulePattern[]
  workScheduleAssignments     WorkScheduleAssignment[]
  workSchedulePatternDays     WorkSchedulePatternDay[]
  payrollPeriods              PayrollPeriod[]
  payrollPeriodSnapshots      PayrollPeriodSnapshot[]
  payrollAuditEvents          PayrollAuditEvent[]
  payrollCodeMappingProfiles  PayrollCodeMappingProfile[]
  screenConfigurationProfiles ScreenConfigurationProfile[]
  homeQuickAccessProfile      HomeQuickAccessProfile?
}

model PayrollPeriod {
  id        String              @id @default(cuid())
  companyId String
  month     String              @db.VarChar(7)
  status    PayrollPeriodStatus @default(OPEN)

  preClosedAt       DateTime? @db.Timestamptz(3)
  preClosedByUserId String?

  closedAt       DateTime? @db.Timestamptz(3)
  closedByUserId String?

  note      String?  @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  preClosedByUser User?                   @relation("PayrollPeriodPreClosedByUser", fields: [preClosedByUserId], references: [id], onDelete: SetNull)
  closedByUser    User?                   @relation("PayrollPeriodClosedByUser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  snapshots       PayrollPeriodSnapshot[]

  @@unique([companyId, month])
  @@index([companyId, status])
  @@index([companyId, month, status])
  @@index([preClosedByUserId])
  @@index([closedByUserId])
}

model PayrollPeriodSnapshot {
  id        String @id @default(cuid())
  companyId String
  periodId  String
  month     String @db.VarChar(7)

  status PayrollSnapshotStatus @default(DRAFT)

  payrollMappingProfile String  @db.VarChar(50)
  dailyExportProfile    String? @db.VarChar(50)
  monthlyExportProfile  String? @db.VarChar(50)

  employeeCount          Int @default(0)
  payrollReadyCount      Int @default(0)
  blockedEmployeeCount   Int @default(0)
  blockedDayCount        Int @default(0)
  reviewRequiredDayCount Int @default(0)
  pendingReviewDayCount  Int @default(0)
  rejectedReviewDayCount Int @default(0)

  createdByUserId String?
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period        PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  createdByUser User?         @relation("PayrollPeriodSnapshotCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  employeeRows PayrollPeriodSnapshotEmployee[]
  codeRows     PayrollPeriodSnapshotCodeRow[]

  @@index([companyId, month])
  @@index([periodId, createdAt])
  @@index([createdByUserId])
}

model PayrollPeriodSnapshotEmployee {
  id         String @id @default(cuid())
  snapshotId String

  employeeId   String
  employeeCode String @db.VarChar(100)
  fullName     String @db.VarChar(200)
  month        String @db.VarChar(7)

  dayCount Int @default(0)

  presentDays Int @default(0)
  absentDays  Int @default(0)
  offDays     Int @default(0)
  leaveDays   Int @default(0)

  annualLeaveDays  Int @default(0)
  sickLeaveDays    Int @default(0)
  excusedLeaveDays Int @default(0)
  unpaidLeaveDays  Int @default(0)
  unknownLeaveDays Int @default(0)

  workedMinutes        Int @default(0)
  overtimeMinutes      Int @default(0)
  overtimeEarlyMinutes Int @default(0)
  overtimeLateMinutes  Int @default(0)
  lateMinutes          Int @default(0)
  earlyLeaveMinutes    Int @default(0)

  blockedDays Int @default(0)
  readyDays   Int @default(0)

  reviewRequiredDays Int @default(0)
  pendingReviewDays  Int @default(0)
  rejectedReviewDays Int @default(0)

  manualAdjustmentDays Int @default(0)
  anomalyDays          Int @default(0)

  puantajCodes Json?

  isPayrollReady Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  snapshot PayrollPeriodSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([snapshotId, employeeId])
  @@index([snapshotId, employeeCode])
}

model PayrollPeriodSnapshotCodeRow {
  id         String @id @default(cuid())
  snapshotId String

  employeeId   String
  employeeCode String @db.VarChar(100)
  fullName     String @db.VarChar(200)
  month        String @db.VarChar(7)

  puantajCode      String                             @db.VarChar(50)
  payrollCode      String                             @db.VarChar(50)
  payrollLabel     String                             @db.VarChar(200)
  unit             PayrollSnapshotQuantityUnit
  quantityStrategy PayrollCodeMappingQuantityStrategy
  fixedQuantity    Decimal?                           @db.Decimal(12, 2)

  quantity     Decimal @db.Decimal(12, 2)
  dayCount     Int     @default(0)
  totalMinutes Int     @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  snapshot PayrollPeriodSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([snapshotId, employeeId])
  @@index([snapshotId, payrollCode])
  @@index([snapshotId, puantajCode])
}

model PayrollAuditEvent {
  id        String  @id @default(cuid())
  companyId String
  month     String? @db.VarChar(7)

  employeeId String? @db.VarChar(100)

  eventType  PayrollAuditEventType
  entityType PayrollAuditEntityType
  entityId   String                 @db.VarChar(100)

  actorUserId String?
  payload     Json?

  createdAt DateTime @default(now()) @db.Timestamptz(3)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser User?   @relation("PayrollAuditEventActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, month, createdAt])
  @@index([companyId, eventType, createdAt])
  @@index([companyId, entityType, entityId, createdAt])
  @@index([companyId, employeeId, createdAt])
  @@index([actorUserId])
}

model PayrollCodeMappingProfile {
  id        String @id @default(cuid())
  companyId String

  code String @db.VarChar(50)
  name String @db.VarChar(200)

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  company Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   PayrollCodeMappingItem[]

  @@unique([companyId, code])
  @@index([companyId, isDefault])
  @@index([companyId, isActive])
  @@index([companyId, createdAt])
}

model PayrollCodeMappingItem {
  id        String @id @default(cuid())
  profileId String

  puantajCode      String                             @db.VarChar(50)
  payrollCode      String                             @db.VarChar(50)
  payrollLabel     String                             @db.VarChar(200)
  unit             PayrollCodeMappingItemUnit
  quantityStrategy PayrollCodeMappingQuantityStrategy
  fixedQuantity    Decimal?                           @db.Decimal(12, 2)

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  profile PayrollCodeMappingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, puantajCode])
  @@index([profileId, isActive, sortOrder])
  @@index([profileId, payrollCode])
  @@index([profileId, puantajCode, isActive])
}

/// Security/audit log for blocked integration attempts (IP, auth, config).
model IntegrationSecurityLog {
  id         String   @id @default(cuid())
  companyId  String?
  reason     String   @db.VarChar(50)
  endpoint   String   @db.VarChar(200)
  sourceIp   String?  @db.VarChar(64)
  userAgent  String?  @db.VarChar(200)
  receivedAt DateTime @default(now()) @db.Timestamptz(3)

  details Json?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([reason])
  @@index([receivedAt])
}

/// Idempotency + trace link between external HR identity and internal Employee.
model IntegrationEmployeeLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId String

  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)
  lastSeenAt DateTime? @db.Timestamptz(3)

  /// Optional: helps detect unchanged payloads without diffing full objects.
  lastPayloadHash String? @db.VarChar(64)

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
}

/// Request-level audit log for enterprise traceability.
model IntegrationLog {
  id        String @id @default(cuid())
  companyId String

  /// Correlation id. Client may send X-Request-Id; otherwise server generates.
  requestId String @unique @db.VarChar(64)

  endpoint     String  @db.VarChar(200)
  sourceSystem String  @db.VarChar(50)
  batchRef     String? @db.VarChar(200)

  ip         String? @db.VarChar(64)
  /// Never store the API key itself. Store a hash/fingerprint for traceability.
  apiKeyHash String? @db.VarChar(64)

  receivedAt  DateTime  @default(now()) @db.Timestamptz(3)
  processedAt DateTime? @db.Timestamptz(3)

  totalCount     Int @default(0)
  createdCount   Int @default(0)
  updatedCount   Int @default(0)
  unchangedCount Int @default(0)
  failedCount    Int @default(0)

  status IntegrationLogStatus @default(SUCCESS)

  /// Optional JSONB details.
  errors      Json?
  payloadMeta Json?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sourceSystem, receivedAt])
}

/// Idempotency link for externally managed leaves (EmployeeLeave).
model IntegrationLeaveLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId String
  leaveId    String

  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)
  lastSeenAt DateTime? @db.Timestamptz(3)

  lastPayloadHash String? @db.VarChar(64)

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leave    EmployeeLeave @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
  @@index([companyId, leaveId])
}

/// Idempotency link for WeeklyShiftPlan (shift assignments).
model IntegrationWeeklyShiftPlanLink {
  id           String @id @default(cuid())
  companyId    String
  sourceSystem String @db.VarChar(50)
  externalRef  String @db.VarChar(200)

  employeeId        String
  weeklyShiftPlanId String

  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)
  lastSeenAt DateTime? @db.Timestamptz(3)

  lastPayloadHash String? @db.VarChar(64)

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  weeklyShiftPlan WeeklyShiftPlan @relation(fields: [weeklyShiftPlanId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceSystem, externalRef])
  @@index([companyId, employeeId])
  @@index([companyId, weeklyShiftPlanId])
}

model CompanyImportProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  kind    ImportProfileKind
  mapping Json

  @@unique([companyId, kind])
  @@index([companyId])
}

model ScreenConfigurationProfile {
  id        String                       @id @default(cuid())
  companyId String
  screenKey ScreenConfigurationScreenKey
  createdAt DateTime                     @default(now()) @db.Timestamptz(3)
  updatedAt DateTime                     @updatedAt @db.Timestamptz(3)

  company Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
