# Device Sync Mode:
# - SIMULATOR (default): Fiziki cihaz yokken Sync butonu simülasyon üretir.
# - REAL: ZKTECO_PULL / ZKTECO_PUSH driver'ları gerçek cihazdan çeker (implement edilecek).
DEVICE_SYNC_MODE="SIMULATOR"

# --- Integration API (Enterprise HR -> PDKS) ---
# Harici HR sistemleri (SAP/LOGO vb.) bu key ile çağrı yapar.
# Cookie/Auth yoktur, sadece header doğrulaması.
INTEGRATION_API_KEY="change_me_in_real_env"
INTEGRATION_MAX_BATCH_SIZE=500

INTEGRATION_IP_ALLOWLIST=
INTEGRATION_TRUST_PROXY=0